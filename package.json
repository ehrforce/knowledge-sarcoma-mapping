{
  "name": "knowledge-sarcoma-mapping",
  "version": "0.1.0",
  "description": "Uttrekk av kunnskapsbasen for Sarkom",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "generate": "npm run build:cli && node dist/cli/index.js -f ./excel/mapping.xlsx",
    "verify": "(npm run build:cli && node dist/cli/index.js -f ./excel/mapping.xlsx )& node dist/cli/index.js -v ./tmp.json"
  },
  "keywords": [
    "openEHR",
    "Sarkom",
    "Kreftjournal"
  ],
  "author": "Bjørn Næss <bna@dips.no>",
  "license": "ISC",
  "dependencies": {
    "@vercel/blob": "^2.0.0",
    "commander": "^12.1.0",
    "ehrcraft-form-api": "^2.4.0",
    "exceljs": "^4.4.0",
    "fast-csv": "^5.0.2",
    "lucide-react": "^0.562.0",
    "next": "^16.2.5",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@prisma/client": "6.0.1",
    "@types/commander": "^2.12.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.2.3",
    "eslint-config-next": "^16.2.5",
    "jest": "^29.7.0",
    "prisma": "6.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "handlebars": ">=4.7.9",
      "minimatch": ">=9.0.7",
      "flatted": ">=3.4.0",
      "undici": ">=8.5.0",
      "picomatch": ">=4.0.4",
      "ajv": ">=6.14.0",
      "postcss": ">=8.5.10",
      "diff": ">=4.0.4",
      "tmp": ">=0.2.6",
      "uuid": ">=11.1.1",
      "js-yaml": ">=4.2.0",
      "@babel/core": ">=7.29.6"
    }
  }
